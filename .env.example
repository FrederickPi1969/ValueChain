# SEC requires a meaningful User-Agent for automated access.
# Include project name and contact email before running larger crawls.
VALUECHAIN_SEC_USER_AGENT="FrederickPi ValueChainPrototype/0.1 contact=you@example.com"

# Optional proxy. Leave blank if the network does not require it.
# VALUECHAIN_HTTP_PROXY="http://proxy.frederickpi.com:8080"
# VALUECHAIN_HTTPS_PROXY="http://proxy.frederickpi.com:8080"

# Default SEC rate limit for this prototype. Keep below SEC's global max.
VALUECHAIN_SEC_RPS=2.0

# Scheduled acquisition daemon. The proxy pool is mandatory; SEC requests do
# not fall back to a direct connection when the pool is unavailable.
VALUECHAIN_PROXY_POOL_URL="https://proxy.frederickpi.com"
VALUECHAIN_FILING_RAW_DIR="/mnt/hdd8tb/filings"
VALUECHAIN_ACQUISITION_STATE="/home/pi/valuechain-state/acquisition.sqlite3"
VALUECHAIN_ACQUISITION_DATABASE_URL="postgresql://valuechain:valuechain_dev@127.0.0.1:5433/valuechain"
VALUECHAIN_ACQUISITION_YEARS="2026,2025"
VALUECHAIN_ACQUISITION_SEC_RPS=1.0
VALUECHAIN_ACQUISITION_CONCURRENCY=4
VALUECHAIN_ACQUISITION_REQUEST_SLEEP_SECONDS=0.5
VALUECHAIN_ACQUISITION_REQUEST_JITTER_SECONDS=0.5
VALUECHAIN_ACQUISITION_ISSUER_LIMIT=3
VALUECHAIN_ACQUISITION_RESCAN_HOURS=24
VALUECHAIN_ACQUISITION_TIMEOUT_SECONDS=60
VALUECHAIN_ACQUISITION_RETRIES=3

# Parallel non-SEC lanes. Each source remains single-process and uses its own
# authority-specific rate limit from the source catalog.
VALUECHAIN_GLOBAL_RAW_DIR="/mnt/hdd8tb/valuechain/global-acquisition"
VALUECHAIN_GLOBAL_ACQUISITION_YEARS="2026,2025"
VALUECHAIN_CNINFO_ISSUER_LIMIT=2
VALUECHAIN_ESEF_FILING_LIMIT=2
VALUECHAIN_GLOBAL_DISCOVERY_REFRESH_HOURS=24

# Corpus storage can be external to the Git checkout. The raw and processed
# paths default below VALUECHAIN_DATA_DIR unless explicitly overridden.
# VALUECHAIN_DATA_DIR="/mnt/hdd8tb/valuechain/data"
# VALUECHAIN_RAW_DIR="/mnt/hdd8tb/valuechain/data/raw"
# VALUECHAIN_PROCESSED_DIR="/mnt/hdd8tb/valuechain/data/processed"
# VALUECHAIN_REPORTS_DIR="/mnt/hdd8tb/valuechain/reports"

# Optional OpenAI-compatible extraction endpoint.
# Rules mode works without this. LLM/hybrid mode uses these settings.
VALUECHAIN_LLM_BASE_URL="http://192.168.50.18:31969/v1"
VALUECHAIN_LLM_API_KEY=1969
VALUECHAIN_EXTRACTION_MODEL="Qwen/Qwen3.5-4B"
VALUECHAIN_COMPLEX_MODEL="Qwen/Qwen3.6-35B-A3B"
VALUECHAIN_EMBEDDING_MODEL="qwen3-embed-0.6b"
VALUECHAIN_LLM_REPORT_URL="http://localllm.frederickpi.com/report"
VALUECHAIN_LLM_CONCURRENCY=4

# Optional local Postgres target. Start it with `docker compose up -d postgres`.
VALUECHAIN_DATABASE_URL="postgresql://valuechain:valuechain_dev@127.0.0.1:5433/valuechain"

# Docker Compose deployment overrides. Keep PostgreSQL on low-latency storage.
# VALUECHAIN_POSTGRES_DATA_DIR="/home/pi/valuechain-state/postgres"
# VALUECHAIN_POSTGRES_PASSWORD="replace-with-a-random-password"
# VALUECHAIN_POSTGRES_BIND="127.0.0.1"
# VALUECHAIN_POSTGRES_PORT=5433
# VALUECHAIN_ADMINER_BIND="127.0.0.1"
# VALUECHAIN_ADMINER_PORT=8081
# VALUECHAIN_API_BIND="127.0.0.1"
# VALUECHAIN_API_PORT=8000

# Backend API / frontend dev.
VALUECHAIN_API_HOST="127.0.0.1"
VALUECHAIN_API_PORT=8000
