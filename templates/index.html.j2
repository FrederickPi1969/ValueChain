<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AI Value Chain Runs</title>
  <style>
    :root {
      --bg: #f4f6f8;
      --surface: #fff;
      --ink: #15212c;
      --muted: #61717f;
      --line: #d8e0e7;
      --teal: #0f766e;
      --blue: #1d4ed8;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: var(--bg);
    }
    header {
      padding: 22px 28px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--line);
    }
    h1 {
      margin: 0 0 6px;
      font-size: 23px;
      letter-spacing: 0;
    }
    .subtitle { color: var(--muted); }
    main {
      padding: 20px 28px 36px;
      display: grid;
      gap: 12px;
    }
    .run-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      padding: 15px 16px;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
    }
    .run-title {
      font-size: 16px;
      font-weight: 650;
      margin-bottom: 5px;
    }
    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 10px;
    }
    .chip {
      display: inline-flex;
      padding: 2px 8px;
      min-height: 24px;
      align-items: center;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fbfcfe;
      color: #34495a;
      font-size: 12px;
    }
    a.button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 36px;
      padding: 7px 11px;
      border-radius: 6px;
      background: var(--teal);
      color: #fff;
      text-decoration: none;
      white-space: nowrap;
    }
    .secondary {
      color: var(--muted);
      font-size: 12px;
      overflow-wrap: anywhere;
    }
    .empty {
      padding: 24px;
      border: 1px dashed var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--muted);
    }
    @media (max-width: 720px) {
      header, main {
        padding-left: 14px;
        padding-right: 14px;
      }
      .run-card {
        grid-template-columns: 1fr;
      }
      a.button {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>AI Value Chain Runs</h1>
    <div class="subtitle">Open a specific industry batch dashboard. Each run has its own artifacts and frontend.</div>
  </header>
  <main>
    {% if runs %}
      {% for run in runs %}
        <section class="run-card">
          <div>
            <div class="run-title">{{ run.run_label }}</div>
            <div class="secondary">{{ run.run_id }} · {{ run.created_at }}</div>
            <div class="meta">
              <span class="chip">Companies {{ run.counts.companies or 0 }}</span>
              <span class="chip">Filings {{ run.counts.filings or 0 }}</span>
              <span class="chip">Evidence {{ run.counts.relation_evidence or 0 }}</span>
              <span class="chip">Edges {{ run.counts.graph_edges or 0 }}</span>
              <span class="chip">Extractor {{ run.options.extractor or "" }}</span>
            </div>
          </div>
          <div>
            <a class="button" href="{{ run.dashboard }}">Open Dashboard</a>
          </div>
        </section>
      {% endfor %}
    {% else %}
      <div class="empty">No runs have been registered yet. Run `valuechain run ...` to generate dashboards.</div>
    {% endif %}
  </main>
</body>
</html>
