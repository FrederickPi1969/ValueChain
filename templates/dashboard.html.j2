<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AI Value Chain Disclosure Dashboard</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #16202a;
      --muted: #617181;
      --line: #d7dee6;
      --bg: #f6f8fb;
      --panel: #ffffff;
      --accent: #0f766e;
      --warn: #9a3412;
    }
    body {
      margin: 0;
      font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: var(--bg);
    }
    header {
      padding: 24px 32px 16px;
      background: #fff;
      border-bottom: 1px solid var(--line);
    }
    h1 {
      margin: 0 0 8px;
      font-size: 26px;
      letter-spacing: 0;
    }
    h2 {
      margin: 0 0 12px;
      font-size: 17px;
      letter-spacing: 0;
    }
    main {
      padding: 20px 32px 36px;
    }
    .metrics {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }
    .metric, section {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
    }
    .metric {
      padding: 14px 16px;
    }
    .metric strong {
      display: block;
      font-size: 24px;
    }
    .metric span {
      color: var(--muted);
    }
    section {
      margin: 16px 0;
      padding: 16px;
      overflow: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 900px;
    }
    th, td {
      border-bottom: 1px solid var(--line);
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    th {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      background: #fbfcfe;
      position: sticky;
      top: 0;
    }
    .pill {
      display: inline-block;
      padding: 2px 7px;
      border-radius: 999px;
      background: #e6f3f1;
      color: var(--accent);
      font-size: 12px;
      white-space: nowrap;
    }
    .risk {
      background: #fff2e8;
      color: var(--warn);
    }
    .evidence {
      max-width: 560px;
    }
    input {
      width: min(420px, 100%);
      padding: 8px 10px;
      border: 1px solid var(--line);
      border-radius: 6px;
      margin-bottom: 10px;
    }
    a { color: #075985; }
  </style>
</head>
<body>
  <header>
    <h1>Disclosure-Derived AI Value Chain Graph</h1>
    <div>Evidence-backed dependency records for portfolio review, bottleneck triage, and validation.</div>
  </header>
  <main>
    <div class="metrics">
      <div class="metric"><strong>{{ company_count }}</strong><span>Companies with edges</span></div>
      <div class="metric"><strong>{{ evidence_count }}</strong><span>Evidence records</span></div>
      <div class="metric"><strong>{{ edge_count }}</strong><span>Aggregated edges</span></div>
      <div class="metric"><strong>{{ bottlenecks|length }}</strong><span>Bottleneck candidates</span></div>
    </div>

    <section>
      <h2>Portfolio Exposure Table</h2>
      <table>
        <thead><tr><th>Company</th><th>Evidence</th><th>Relation Types</th><th>Sector</th><th>Industry</th><th>Market Cap</th></tr></thead>
        <tbody>
        {% for row in company_context %}
          <tr>
            <td>{{ row.company }}</td>
            <td>{{ row.evidence_count }}</td>
            <td>{{ row.relation_types }}</td>
            <td>{{ row.sector }}</td>
            <td>{{ row.industry }}</td>
            <td>{{ row.marketCap }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Bottleneck Candidates</h2>
      <table>
        <thead><tr><th>Dependency Object</th><th>Dependent Companies</th><th>Evidence</th><th>Relation Types</th><th>Subjects</th></tr></thead>
        <tbody>
        {% for row in bottlenecks %}
          <tr>
            <td>{{ row.object }}</td>
            <td>{{ row.dependent_company_count }}</td>
            <td>{{ row.evidence_count }}</td>
            <td>{{ row.relation_types }}</td>
            <td>{{ row.subjects }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Aggregated Edges</h2>
      <input id="edgeFilter" placeholder="Filter edges by company, object, relation, modality">
      <table id="edgeTable">
        <thead><tr><th>Subject</th><th>Object</th><th>Relation</th><th>Modality</th><th>Evidence</th><th>Confidence</th><th>Window</th><th>Forms</th></tr></thead>
        <tbody>
        {% for edge in edges %}
          <tr>
            <td>{{ edge.subject }}</td>
            <td>{{ edge.object }}</td>
            <td>{{ edge.relation_type }}</td>
            <td><span class="pill {% if edge.modality == 'risk_hypothetical' %}risk{% endif %}">{{ edge.modality }}</span></td>
            <td>{{ edge.evidence_count }}</td>
            <td>{{ edge.avg_confidence }}</td>
            <td>{{ edge.first_seen }} to {{ edge.last_seen }}</td>
            <td>{{ edge.forms }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Evidence Inspector</h2>
      <input id="evidenceFilter" placeholder="Filter evidence by company, section, relation, text">
      <table id="evidenceTable">
        <thead><tr><th>Company</th><th>Relation</th><th>Object</th><th>Modality</th><th>Form</th><th>Date</th><th>Section</th><th>Evidence</th><th>Source</th></tr></thead>
        <tbody>
        {% for row in evidence %}
          <tr>
            <td>{{ row.subject }}</td>
            <td>{{ row.relation_type }}</td>
            <td>{{ row.object }}</td>
            <td><span class="pill {% if row.modality == 'risk_hypothetical' %}risk{% endif %}">{{ row.modality }}</span></td>
            <td>{{ row.form }}</td>
            <td>{{ row.filing_date }}</td>
            <td>{{ row.source_section }}</td>
            <td class="evidence">{{ row.evidence_text }}</td>
            <td><a href="{{ row.source_document_url }}">filing</a></td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </section>
  </main>
  <script>
    function bindFilter(inputId, tableId) {
      const input = document.getElementById(inputId);
      const rows = Array.from(document.querySelectorAll(`#${tableId} tbody tr`));
      input.addEventListener('input', () => {
        const q = input.value.toLowerCase();
        rows.forEach(row => {
          row.style.display = row.innerText.toLowerCase().includes(q) ? '' : 'none';
        });
      });
    }
    bindFilter('edgeFilter', 'edgeTable');
    bindFilter('evidenceFilter', 'evidenceTable');
  </script>
</body>
</html>
